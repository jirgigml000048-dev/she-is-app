        border-radius: 14px;
        background: rgba(244,240,228,0.7);
        border-bottom: 2px solid var(--coral);
      }

      .story-subtitle {
        margin: 0 0 10px;
        font-size: 16px;
        line-height: 1.5;
        font-weight: 500;
        color: var(--ink);
      }

      .pill-wrap { display: flex; flex-wrap: wrap; gap: 8px; }

      .story-tag {
