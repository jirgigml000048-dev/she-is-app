        border: 1px solid var(--teal);
        color: var(--ink);
        border-radius: 12px;
        padding: 10px 14px;
        background: rgba(58,66,17,0.08);
        font-size: 13px;
        letter-spacing: 0.02em;
      }

      .story-cta strong { color: var(--teal); }
