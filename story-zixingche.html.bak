<title>自行车：30岁却像15岁的赛博格 | 女也 She Is</title>
    
    <style>
      :root {
        --bg: #F4F0E4;
        --ink: #2C2C2C;
        --teal: #3a4211;
        --slate: #7a9248;
        --coral: #f8c7e4;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--bg);
        background-image: radial-gradient(ellipse 90% 75% at 0% 0%, rgba(232,121,160,0.18) 0%, transparent 60%),
          radial-gradient(ellipse 80% 70% at 100% 5%, rgba(167,139,250,0.2) 0%, transparent 55%),
          radial-gradient(ellipse 70% 80% at 0% 100%, rgba(96,165,250,0.15) 0%, transparent 55%),
          radial-gradient(ellipse 75% 60% at 100% 90%, rgba(249,115,22,0.12) 0%, transparent 50%);
        color: var(--ink);
        font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", "STSong", "SimSun", serif;
      }

      .page {
        max-width: 480px;
        margin: 0 auto;
        min-height: 100vh;
        padding-top: 56px;
        padding-bottom: 48px;
      }

      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        max-width: 480px;
        margin: 0 auto;
        border-bottom: 1px solid rgba(122,146,72,0.2);
        background: rgba(244,240,228,0.95);
        backdrop-filter: blur(6px);
      }

      .back-btn {
        font-size: 12px;
        letter-spacing: 0.06em;
        text-decoration: none;
        color: var(--ink);
      }

      .page-header-row {
        display: flex;
        
        
        width: 100%;
        margin-bottom: 0;
      
        justify-content: space-between;
        align-items: flex-start;
      }

      .logo {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        margin: 0 0 0 auto;
      }

      .logo-cn {
        display: block;
        font-family: "Lora", serif;
        font-size: 18px;
        line-height: 1;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--ink);
      }

      .logo-en {
        display: block;
        font-family: "Courier Prime", monospace;
        font-size: 10px;
        letter-spacing: 0.08em;
        color: rgba(44,44,44,0.62);
